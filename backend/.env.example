# Copy this file to .env and fill in your own values.

# --- Database ---
# SQLite works out of the box for a quick demo (no setup needed).
# For Postgres:  postgresql+psycopg2://user:password@localhost:5432/aivoa_complaints
# For MySQL:     mysql+pymysql://user:password@localhost:3306/aivoa_complaints
DATABASE_URL=sqlite:///./aivoa_complaints.db

# --- Groq (https://console.groq.com) ---
GROQ_API_KEY=
GROQ_MODEL=gemma2-9b-it
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:3000

# --- Uploads ---
UPLOAD_DIR=./uploads
